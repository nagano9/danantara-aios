# Normalize every text file to LF, in the repository and in the working tree.
#
# This is load-bearing, not cosmetic. validate_skills.py compares each SKILL.md
# `description:` against the matching column in master_skill_registry.csv as an
# exact string. A CR smuggled into either side by a Windows checkout makes that
# comparison fail for all 133 skills at once, so the line ending has to be
# pinned rather than left to each contributor's core.autocrlf.
* text=auto eol=lf

# Explicit: the registry and schemas are parsed, not just read.
*.csv text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.mmd text eol=lf
*.py text eol=lf

# Never normalize binaries.
*.zip binary
*.pdf binary
*.png binary
*.jpg binary
*.xlsx binary
*.docx binary
*.pptx binary
